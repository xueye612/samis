# SAMIS API base — include /api-samis/pc/v1 exactly once (no duplicate in paths)
# Dev (Vite proxy): relative path
VITE_SAMIS_API_BASE=/api-samis/pc/v1
# Direct: VITE_SAMIS_API_BASE=http://47.105.38.226:8022/api-samis/pc/v1

VITE_SAMIS_REQUEST_TIMEOUT_MS=30000

# Legacy global switch (false = prefer real for modules that default to real)
VITE_ANESTHESIA_USE_MOCK=true

# Per-module real API switches
VITE_USE_REAL_AUTH=true
VITE_USE_REAL_OPERATION_INFO=true
VITE_USE_REAL_ROOM=true
# true = 药品字典走远程；为空时页面显示「暂无数据」，不会自动填充演示药品
VITE_USE_REAL_ANESTHESIA_DICT=false
VITE_USE_REAL_ANESTHESIA_RECORD=false
VITE_USE_REAL_ANESTHESIA_SYNC=false
VITE_USE_REAL_DEVICE=false
VITE_USE_REAL_PACU=false
VITE_USE_REAL_POSTOPERATIVE=false

# Skip login guard (local E2E / demo only)
# VITE_AUTH_LOGIN_BYPASS=true
